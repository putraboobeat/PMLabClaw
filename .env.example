# PmlabClaw Configuration
# Salin file ini menjadi .env dan isi dengan nilai yang sesuai
# JANGAN pernah commit file .env ke git!

# === Telegram ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ALLOWED_CHAT_ID=your_telegram_chat_id_here

# === WhatsApp (Evolution API / WAHA) ===
WHATSAPP_API_URL=http://localhost:8081/message/sendText/InstanceName
WHATSAPP_API_KEY=your_evolution_api_key_here
ALLOWED_WA_NUMBER=6281234567890
WHATSAPP_WEBHOOK_PORT=8080

# === LLM API (AgentRouter / OpenAI-compatible) ===
API_KEY=your_api_key_here
API_BASE_URL=https://agentrouter.org/v1
MODEL_NAME=deepseek-v4-flash

# === Agent Behavior ===
# Jumlah maksimal iterasi tool calling per pesan (hemat token)
MAX_TOOL_ITERATIONS=5
# Jumlah maksimal riwayat chat yang dipertahankan
MAX_HISTORY_LENGTH=20
# Timeout untuk long polling Telegram (detik)
TELEGRAM_POLL_TIMEOUT=50
# Timeout untuk eksekusi perintah shell (detik)
SHELL_TIMEOUT=30

# === StarSender V3 (WhatsApp Gateway) ===
# Masukkan API Key dari dashboard StarSender Anda
STARSENDER_API_KEY=your_starsender_api_key_here
# Port lokal untuk menerima webhook dari StarSender
STARSENDER_WEBHOOK_PORT=8081
# Nomor WA utama Anda untuk otorisasi akses (gunakan format 628...)
ALLOWED_WA_NUMBER=your_whatsapp_number_here
